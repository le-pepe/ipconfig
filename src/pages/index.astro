---
import Layout from '../layouts/Layout.astro';
import { getClientIpFromHeaders } from '../lib/client-ip';

const { headers } = Astro.request;
// export const prerender = false;

const clientIp = getClientIpFromHeaders(headers, Astro.clientAddress);
const requestDetails = [
    ['User Agent', headers.get('user-agent') ?? 'No disponible'],
    ['Language', headers.get('accept-language') ?? 'No disponible'],
    ['Referer', headers.get('referer') ?? 'Directo'],
    ['Method', Astro.request.method],
    ['Encoding', headers.get('accept-encoding') ?? 'No disponible'],
    ['MIME', headers.get('accept') ?? 'No disponible'],
];
---

<Layout>
    <section class="ip-panel">
        <div class="ip-card">
            <div class="card-topline">
                <span class="card-label mono">IP</span>
                <button class="copy-button" type="button" data-copy={clientIp} aria-label="Copiar IP">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-copy-icon lucide-copy"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                </button>
            </div>
            <strong class="ip-value mono">{clientIp}</strong>
        </div>

        <article class="info-card">
            <div class="card-topline">
                <span class="badge mono">CURL</span>
                <button class="copy-button" type="button" data-copy="curl ip.lepepe.dev" aria-label="Copiar comando curl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-copy-icon lucide-copy"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                </button>
            </div>
            <div class="command-line">
                <code class="mono">curl ip.lepepe.dev</code>
            </div>
        </article>

        <section class="details-card">
            <div class="card-topline">
                <span class="badge mono">HEADERS</span>
            </div>

            <div class="details-grid">
                {requestDetails.map(([label, value]) => (
                    <article class="detail-row">
                        <span class="detail-label">{label}</span>
                        <span class="detail-value mono">{value}</span>
                    </article>
                ))}
            </div>
        </section>
    </section>
</Layout>

<style>
    .ip-panel {
        width: min(1120px, 100%);
        display: grid;
        gap: 1.2rem;
        padding: 1rem 0;
    }

    .hero-copy {
        display: none;
    }

    .ip-card,
    .info-card,
    .details-card {
        border: 1px solid var(--border);
        background: var(--surface);
        backdrop-filter: blur(18px);
        box-shadow: var(--shadow);
    }

    .ip-card {
        display: grid;
        gap: 0.65rem;
        padding: 1.1rem 1.2rem 1.2rem;
        border-radius: 1.8rem;
        animation: rise 650ms ease-out both;
        justify-items: center;
        text-align: center;
    }

    .card-label,
    .badge {
        color: var(--muted);
        font-size: 0.76rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .card-topline {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        width: 100%;
    }

    .copy-button {
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text);
        border-radius: 999px;
        width: 2.35rem;
        height: 2.35rem;
        padding: 0;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: border-color 180ms ease, background 180ms ease, transform 180ms ease;
    }

    .copy-button:hover {
        border-color: var(--accent);
        background: var(--surface-strong);
        transform: translateY(-1px);
    }

    .copy-button svg {
        width: 1rem;
        height: 1rem;
        fill: none;
        stroke: currentColor;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        flex: none;
    }

    .ip-value {
        display: block;
        font-size: clamp(2rem, 6vw, 4.75rem);
        line-height: 1;
        overflow-wrap: anywhere;
        max-width: 100%;
    }

    .info-card,
    .details-card {
        border-radius: 1.5rem;
        padding: 1.1rem 1.2rem 1.2rem;
    }

    .command-line {
        padding: 1rem 1.05rem;
        border-radius: 1rem;
        margin-top: 0.85rem;
        background: var(--surface-strong);
        border: 1px solid var(--border);
        overflow-x: auto;
    }

    .command-line code {
        font-size: 0.96rem;
        white-space: nowrap;
    }

    .details-card {
        animation: rise 900ms ease-out both;
    }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem;
        margin-top: 0.85rem;
    }

    .detail-row {
        min-width: 0;
        display: grid;
        gap: 0.45rem;
        padding: 0.95rem 1rem;
        border-radius: 1rem;
        border: 1px solid var(--border);
        background: var(--surface-strong);
    }

    .detail-label {
        color: var(--muted);
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .detail-value {
        min-width: 0;
        font-size: 0.95rem;
        line-height: 1.55;
        overflow-wrap: anywhere;
    }

    @keyframes rise {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 840px) {
        .details-grid {
            grid-template-columns: 1fr;
        }

        .ip-panel {
            gap: 1rem;
        }
    }

    @media (max-width: 640px) {
        h1 {
            max-width: 10ch;
        }

        .ip-card,
        .info-card,
        .details-card {
            border-radius: 1.2rem;
        }

        .card-header,
        .card-topline {
            align-items: flex-start;
        }

        .command-line code {
            white-space: pre-wrap;
            word-break: break-word;
        }
    }
</style>

<script>
    document.querySelectorAll('[data-copy]').forEach((button) => {
        button.addEventListener('click', async () => {
            const text = button.getAttribute('data-copy') ?? '';
            try {
                await navigator.clipboard.writeText(text);
                button.classList.add('is-copied');
                window.setTimeout(() => {
                    button.classList.remove('is-copied');
                }, 1200);
            } catch {}
        });
    });
</script>
